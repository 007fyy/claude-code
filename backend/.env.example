DATABASE_URL=mysql+pymysql://root:yourpassword@127.0.0.1:3306/longshi?charset=utf8mb4
JWT_SECRET=your-secret-key-here
DEBUG=True

# QQ 邮箱 SMTP（留空则使用 mock 模式，验证码打印到控制台）
# 开启步骤：QQ邮箱 → 设置 → 账户 → POP3/SMTP服务 → 开启 → 获取授权码
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USER=your-qq-email@qq.com
EMAIL_PASSWORD=your-qq-email-auth-code
